{
  "name": "mqttlooter",
  "productName": "MQTTLooter",
  "version": "0.3.0",
  "description": "An MQTT client for exploring topics and messages.",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "dist": "electron-vite build && electron-builder",
    "pack": "electron-vite build && electron-builder --dir",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,css}\""
  },
  "build": {
    "appId": "com.martinjensen37.mqttlooter",
    "productName": "MQTTLooter",
    "copyright": "Copyright © 2025 martinjensen37",
    "directories": {
      "output": "dist-builder"
    },
    "files": [
      "out/**/*",
      "assets/**/*",
      "package.json",
      "!**/*.map",
      "!**/*.md"
    ],
    "compression": "maximum",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/MQTTLooter_logo_small.ico",
      "publisherName": "martinjensen37",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MQTTLooter",
      "installerIcon": "assets/MQTTLooter_logo_small.ico",
      "uninstallerIcon": "assets/MQTTLooter_logo_small.ico",
      "installerHeaderIcon": "assets/MQTTLooter_logo_small.ico",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "artifactName": "${productName} Setup ${version}.${ext}",
      "differentialPackage": false
    }
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@tanstack/react-virtual": "^3.14.3",
    "mqtt": "^5.13.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-split-pane": "^3.2.0"
  },
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^36.5.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "prettier": "^3.8.4",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.62.0",
    "vite": "^5.4.0"
  }
}
